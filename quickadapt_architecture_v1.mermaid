---
title: "QuickAdapt Pipeline v1"
---
flowchart TD
    %% ── INTAKE LAYER (Make) ──────────────────────────────
    subgraph MAKE["☁️ Make Scenario: Intake"]
        direction TB
        GF["📋 Google Form
        (tool name, workspace URL, submitter email)"]
        MT["⚡ Make Trigger
        (Watch Form Responses)"]
        MH["🔗 HTTP Module
        (POST to Orchestrator)"]
        GF --> MT --> MH
    end

    %% ── LAYER 0 — ORCHESTRATOR ───────────────────────────
    subgraph L0["Layer 0 — Orchestrator"]
        direction LR
        ORC["🔄 Python State Machine
        (receives webhook payload)"]
        ORC_NOTE["🔄 Orchestrator manages all
        state transitions across the pipeline"]
    end

    MAKE -- "JSON payload:
    {toolName, workspaceUrl, submittedBy}" --> ORC

    %% ── LAYER 1 — TOOL DISCOVERY ─────────────────────────
    subgraph L1["Layer 1 — Tool Discovery"]
        direction TB
        TD["🔍 ToolDiscovery
        (validates + enriches intake data)"]
        DEDUP{"🔎 Dedup Check
        (toolName + workspaceUrl)"}
        TD --> DEDUP
    end

    ORC --> TD

    %% ── DEDUP SHORT-CIRCUIT ──────────────────────────────
    DUP_NOTIFY["📨 Notify Submitter
    (already connected / in-progress)"]
    DEDUP -- "Same tool,
    same workspace" --> DUP_NOTIFY

    %% ── LAYER 2 — CLASSIFICATION ─────────────────────────
    subgraph L2["Layer 2 — Classification"]
        direction TB
        TP["📄 ToolsParser
        (extracts API docs, endpoints, auth type)"]
        GNC["✅ GleanNativeChecker
        (checks Glean's connector catalog)"]
        TP --> GNC
    end

    DEDUP -- "New tool" --> TP

    %% ── LAYER 3a — NATIVE CONNECTOR PATH ─────────────────
    subgraph NATIVE_PATH["Layer 3a — Native Connector"]
        NC["🔌 NativeConnector
        (auto-configure via Glean Admin API)"]
    end

    GNC -- "Native connector
    exists" --> NC

    %% ── LAYER 3b — CUSTOM ADAPTER PATH ───────────────────
    subgraph CUSTOM_PATH["Layer 3b — Custom Adapter"]
        direction TB
        AR["📚 AdapterRegistry
        (check for existing adapter)"]
        AW["🤖 AdapterWriter
        (OpenClaw AI generates adapter code)"]
        SV["🛡️ SchemaValidator
        (validate against universal_schema.json)"]
        QA{"🧪 QA Pass?"}
        RETRY["🔁 Retry w/ Failure Context
        (feed errors back to AdapterWriter)"]
        HUMAN["👤 Human Escalation
        (full diagnostic payload)"]
        AR -- "No existing adapter" --> AW
        AW --> SV
        SV --> QA
        QA -- "Fail (1st attempt)" --> RETRY
        RETRY --> AW
        QA -- "Fail (2nd attempt)" --> HUMAN
    end

    GNC -- "No native
    connector" --> AR

    %% ── MAKE FAILURE ESCALATION PATH ─────────────────────
    subgraph ESCALATE["☁️ Make: Failure Escalation"]
        direction TB
        SE["🚨 Slack Alert
        (ops engineering channel)"]
        ET["📎 Diagnostic Payload
        (adapter code, error logs, source context)"]
        SE --> ET
    end

    HUMAN --> SE
    NC -- "config fails" --> SE

    %% ── LAYER 4 — SYNC SCHEDULER ─────────────────────────
    subgraph SYNC["Layer 4 — SyncScheduler"]
        direction TB
        SS["⏱️ SyncScheduler
        (per-tool incremental sync)"]
        TIERS["📊 Tiered Cadence
        High: ~30min | Med: ~2hr | Low: ~12hr"]
        DELTA["🔄 Delta Sync
        (syncedAt / updatedAt comparison)"]
        SS --> TIERS --> DELTA
    end

    QA -- "Pass" --> SS
    AR -- "Adapter found" --> SS
    DEDUP -- "Same tool,
    new workspace" --> SS

    %% ── GLEAN TARGET ─────────────────────────────────────
    GLEAN["🏢 Glean Indexing API
    (documents pushed via custom connector
    or synced via native connector)"]

    DELTA --> GLEAN
    NC --> GLEAN

    %% ── API RESPONSE → ORCHESTRATOR → NOTIFICATIONS ──────
    GLEAN -- "HTTP response" --> ORC

    subgraph NOTIFY["☁️ Make: Notifs"]
        direction LR
        SN["📨 Slack Notification
        (integration status to ops channel)"]
        EM["📧 Email Confirmation
        (to original submitter)"]
    end

    ORC -- "on success" --> SN
    ORC -- "on success" --> EM